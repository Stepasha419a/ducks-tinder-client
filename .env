PROXY_DNS=127.0.0.11
PROXY_DNS_VALID_TIME=30s

VAR_ROOT_PATH=
PROXY_ROOT_PATH=/

VAR_CLIENT_ROOT_URL=https://localhost
VAR_USER_SERVICE_URL=https://localhost/user-service-url
VAR_CHAT_SERVICE_URL=https://localhost/chat-service-url
VAR_CHAT_SERVICE_SOCKET_PATH=/chat-service-url/chat/socket
VAR_FILE_SERVICE_URL=https://localhost/file-service-url
VAR_AUTH_SERVICE_URL=https://localhost/auth-service-url

VAR_MODE=dev
VAR_POLICY_MFE_URL=https://localhost
VAR_CHAT_MFE_URL=https://localhost

PROXY_SERVER_NAME=localhost
PROXY_CERT_PATH=/etc/nginx/cert/tls.crt
PROXY_KEY_PATH=/etc/nginx/cert/tls.key

PROXY_USER_SERVICE=/user-service-url
PROXY_CHAT_SERVICE=/chat-service-url
PROXY_FILE_SERVICE=/file-service-url
PROXY_AUTH_SERVICE=/auth-service-url

PROXY_USER_SERVICE_URL=https://host.docker.internal:5000
PROXY_CHAT_SERVICE_URL=https://host.docker.internal:5001
PROXY_FILE_SERVICE_URL=https://host.docker.internal:5002
PROXY_AUTH_SERVICE_URL=https://host.docker.internal:5003