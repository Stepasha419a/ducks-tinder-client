PROXY_DNS=127.0.0.11
PROXY_DNS_VALID_TIME=30s

VAR_ROOT_PATH=/dev
PROXY_ROOT_PATH=/dev

VAR_CLIENT_ROOT_URL=https://localhost
VAR_USER_SERVICE_URL=https://localhost/dev/user-service-url
VAR_CHAT_SERVICE_URL=https://localhost/dev/chat-service-url
VAR_CHAT_SERVICE_SOCKET_PATH=/dev/chat-service-url/chat/socket
VAR_FILE_SERVICE_URL=https://localhost/dev/file-service-url
VAR_AUTH_SERVICE_URL=https://localhost/dev/auth-service-url

VAR_MODE=dev
VAR_POLICY_MFE_URL=https://localhost/dev
VAR_CHAT_MFE_URL=https://localhost/dev

PROXY_SERVER_NAME=localhost
PROXY_CERT_PATH=/etc/nginx/cert/tls.crt
PROXY_KEY_PATH=/etc/nginx/cert/tls.key

PROXY_USER_SERVICE=/dev/user-service-url
PROXY_CHAT_SERVICE=/dev/chat-service-url
PROXY_FILE_SERVICE=/dev/file-service-url
PROXY_AUTH_SERVICE=/dev/auth-service-url

PROXY_USER_SERVICE_URL=https://host.docker.internal:5000
PROXY_CHAT_SERVICE_URL=https://host.docker.internal:5001
PROXY_FILE_SERVICE_URL=https://host.docker.internal:5002
PROXY_AUTH_SERVICE_URL=https://host.docker.internal:5003